{
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "framework": "static",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://jee-rank-backend.onrender.com/api/$1"
    }
  ]
}
